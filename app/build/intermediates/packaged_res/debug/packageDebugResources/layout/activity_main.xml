<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B280FF">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <EditText
                android:id="@+id/searchBar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_margin="20dp"
                android:background="@drawable/bg_edittext"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="12dp"
                android:elevation="4dp"
                android:hint="Search"
                android:paddingLeft="15dp"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivCatMain"
                android:layout_width="208dp"
                android:layout_height="208dp"
                android:elevation="2dp"
                android:src="@drawable/ic_cat"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/searchBar" />

            <TextView
                android:id="@+id/tvMewGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cloud"
                android:elevation="4dp"
                android:padding="18dp"
                android:text="Mew : Hey user, How are you feeling this morning ??"
                android:textColor="#2E007E"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivCatMain" />

            <TextView
                android:id="@+id/tvLabel1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="Start Your Great Day !"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvMewGreeting" />

            <LinearLayout
                android:id="@+id/cardSleepReflection"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_cloud"
                android:elevation="4dp"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvLabel1">

                <ImageView
                    android:id="@+id/ivBulan"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/bulan"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvMewGreeting2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sleep Reflection\nWas there anything you want to say before sleep ?"
                    android:textColor="#2E007E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvLabel2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="Today's Goals"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardSleepReflection" />

            <LinearLayout
                android:id="@+id/cardMorningWorkout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_cloud"
                android:elevation="4dp"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvLabel2">

                <ImageView
                    android:id="@+id/ivSun"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/sun"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvMewGreeting3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Morning Workout\nStart The Day With The Energy!"
                    android:textColor="#2E007E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp" />

                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#7C4DFF"
                    android:checked="true"
                    android:scaleX="1.2"
                    android:scaleY="1.2" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:id="@+id/ivSmallIcon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="32dp"
                    android:elevation="5dp"
                    android:src="@drawable/smal" />

                <ImageView
                    android:id="@+id/ivPlus"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginHorizontal="32dp"
                    android:elevation="6dp"
                    android:src="@drawable/ic_plus" />

                <ImageView
                    android:id="@+id/ivNote"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="32dp"
                    android:elevation="5dp"
                    android:src="@drawable/ic_note" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>